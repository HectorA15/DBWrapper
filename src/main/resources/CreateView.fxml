<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="createView" alignment="TOP_CENTER" spacing="4.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.hectora15.controllers.CreateViewController"
      stylesheets="@style.css">

    <padding><Insets bottom="8.0" left="8.0" right="8.0" top="8.0" /></padding>

    <Label text="Create Table" alignment="CENTER_RIGHT">
        <font><Font size="14.0" /></font>
        <VBox.margin><Insets bottom="6.0" top="4.0" /></VBox.margin>
    </Label>

    <GridPane>
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" prefWidth="55.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints prefHeight="30.0" />
        </rowConstraints>
        <children>
            <Label text="Table:" GridPane.valignment="CENTER">
                <font><Font size="13.0" /></font>
            </Label>
            <TextField fx:id="createTableField" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER">
                <GridPane.margin><Insets left="4.0" /></GridPane.margin>
            </TextField>
        </children>
    </GridPane>

    <GridPane>
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" prefWidth="115.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints prefHeight="30.0" />
        </rowConstraints>
        <children>
            <Label text="Columns quantity" GridPane.valignment="CENTER">
                <font><Font size="13.0" /></font>
            </Label>
            <TextField fx:id="createQuantityField" alignment="CENTER" prefHeight="25.0"
                       GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER">
                <GridPane.margin><Insets left="4.0" /></GridPane.margin>
            </TextField>
        </children>
        <VBox.margin><Insets top="4.0" /></VBox.margin>
    </GridPane>

    <!-- Headers -->
    <GridPane>
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints prefHeight="28.0" />
        </rowConstraints>
        <children>
            <Label text="Column Name" styleClass="column-header-label"
                   GridPane.halignment="CENTER" GridPane.valignment="CENTER" />
            <Label text="Data Type" styleClass="column-header-label"
                   GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.valignment="CENTER" />
        </children>
        <VBox.margin><Insets top="8.0" /></VBox.margin>
        <padding><Insets bottom="2.0" left="4.0" right="4.0" top="2.0" /></padding>
    </GridPane>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <content>
            <GridPane fx:id="gridValues" vgap="5.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" />
                    <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
                </columnConstraints>
                <padding><Insets bottom="4.0" left="4.0" right="4.0" top="4.0" /></padding>
            </GridPane>
        </content>
    </ScrollPane>

    <Button fx:id="createButton" mnemonicParsing="false"
            prefHeight="28.0" prefWidth="220.0" text="Create">
        <VBox.margin><Insets bottom="4.0" top="6.0" /></VBox.margin>
    </Button>

</VBox>

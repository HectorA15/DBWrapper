<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="selectView" prefHeight="200.0" prefWidth="100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.hectora15.controllers.SelectViewController">
    <children>
        <VBox fx:id="selectVbox" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" VBox.vgrow="ALWAYS">
            <children>
                <TitledPane fx:id="selectTableTitled" prefHeight="200.0" prefWidth="200.0" text="Tables">
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <content>
                        <ScrollPane fx:id="selectTableScroll">
                            <content>
                                <VBox fx:id="selectTableVbox" />
                            </content>
                        </ScrollPane>
                    </content>
                </TitledPane>
            <VBox fx:id="selectColumnVBox" prefHeight="200.0" prefWidth="100.0" />
            </children>
        </VBox>
    </children>
</VBox>
